# ── Required ───────────────────────────────────────────────────────────────
# OpenAI-compatible upstream base URL (no trailing /chat/completions).
# Examples:
#   Google Gemini (OpenAI-compat): https://generativelanguage.googleapis.com/v1beta/openai
#   OpenAI:                        https://api.openai.com/v1
#   Cerebras:                      https://api.cerebras.ai/v1
#   Your Manifest gateway:         https://<your-gateway>/v1
UPSTREAM_BASE_URL=

# The REAL provider/gateway key. Lives only here (server env) — never in the client.
UPSTREAM_API_KEY=

# ── Optional: Groq free tier as the primary model ────────────────────────────
# When set, every request tries Groq FIRST (fast, free), and falls back to
# UPSTREAM_BASE_URL above on any Groq error, rate limit, timeout, or empty
# response. Leave GROQ_API_KEY blank to disable and go straight to upstream.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=12000

# ── Optional ───────────────────────────────────────────────────────────────
# Default model if the client doesn't send one. Use 'auto' to let the Manifest
# gateway behind UPSTREAM_BASE_URL pick the model.
DEFAULT_MODEL=auto

# Comma-separated allowlist. If set, only these models are accepted.
# With gateway 'auto' routing, keep this 'auto' (or blank to allow all).
ALLOWED_MODELS=auto

# Revocable public app token. If set, the extension must send it as
# Authorization: Bearer <token>. Rotate it to cut off abuse.
APP_TOKEN=

# ── Rate limiting (Upstash Redis REST) ───────────────────────────────────────
# REQUIRED for enforcement — serverless has no shared memory, so without these
# the limits below are NOT applied. Create a free Redis at https://upstash.com,
# then paste its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Per-user (per install) daily cap — the main control.
DAILY_LIMIT_PER_USER=100
# Per-IP daily cap (defeats client-id rotation; a few users may share an IP).
DAILY_LIMIT_PER_IP=300
# Per-IP burst cap, per minute.
RATE_LIMIT_PER_MIN=20
# Optional global backstop across ALL users per day (0 = disabled).
GLOBAL_DAILY_CAP=0
